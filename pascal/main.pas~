program EstimatePi;

function gcd(const a, b : Integer): Integer;
begin
    if b = 0 then
        Result := a
    else
        Result := gcd(b, a mod b)
end;

function coprime(const a, b : Integer): Boolean;
begin
    Result := gcd(a, b) = 1
end;

